# ============================================================
# DietQ Web — Environment Variables
# ============================================================
# SALIN ke .env.local dan isi nilai sebenarnya
# JANGAN commit .env.local ke git!
# ============================================================

# Supabase (dari Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Arkoda LLM Gateway (SERVER-SIDE ONLY — jangan expose ke client!)
# Ini hanya untuk API routes, BUKAN untuk client-side code.
# ⚠️ Prefix ARKODA_ (BUKAN ANTHROPIC_) agar tidak bentrok/ditimpa env var
# sistem milik Claude Code di mesin developer.
ARKODA_BASE_URL=https://api.arkoda.cloud
ARKODA_API_KEY=sk-your-token-here
ARKODA_MODEL=kr/claude-opus-4.6
